": "http://books.google.co.in/books?id=wJ4fjwEACAAJ&dq=dc+comics&hl=&source=gbs_api", "canonicalVolumeLink": "https://books.google.com/books/about/The_DC_Comics_Encyclopedia.html?hl=&id=wJ4fjwEACAAJ"}, "saleInfo": {"country": "IN", "saleability": "NOT_FOR_SALE", "isEbook": false}, "accessInfo": {"country": "IN", "viewability": "NO_PAGES", "embeddable": false, "publicDomain": false, "textToSpeechPermission": "ALLOWED", "epub": {"isAvailable": false}, "pdf": {"isAvailable": false}, "webReaderLink": "http://play.google.com/books/reader?id=wJ4fjwEACAAJ&hl=&source=gbs_api", "accessViewStatus": "NONE", "quoteSharingAllowed": false}, "searchInfo": {"textSnippet": "&quot;This definitve encyclopedia features more than 1,000 characters from over 75 years of DC Comics history&quot;--Front jacket flap."}}, {"kind": "books#volume", "id": "YjCeAAAACAAJ", "etag": "pGj17ItyNb0", "selfLink": "https://www.googleapis.com/books/v1/volumes/YjCeAAAACAAJ", "volumeInfo": {"title": "Dc Comics", "subtitle": "Sixty Years of the World's Favorite Comic Book Heroes", "authors": ["Les Daniels"], "publishedDate": "2001-08-01", "industryIdentifiers": [{"type": "ISBN_10", "identifier": "076285054X"}, {"type": "ISBN_13", "identifier": "9780762850549"}], "readingModes": {"text": false, "image": false}, "pageCount": 256, "printType": "BOOK", "categories": ["Juvenile Fiction"], "maturityRating": "NOT_MATURE", "allowAnonLogging": false, "contentVersion": "preview-1.0.0", "language": "en", "previewLink": "http://books.google.co.in/books?id=YjCeAAAACAAJ&dq=dc+comics&hl=&cd=46&source=gbs_api", "infoLink": "http://books.google.co.in/books?id=YjCeAAAACAAJ&dq=dc+comics&hl=&source=gbs_api", "canonicalVolumeLink": "https://books.google.com/books/about/Dc_Comics.html?hl=&id=YjCeAAAACAAJ"}, "saleInfo": {"country": "IN", "saleability": "NOT_FOR_SALE", "isEbook": false}, "accessInfo": {"country": "IN", "viewability": "NO_PAGES", "embeddable": false, "publicDomain": false, "textToSpeechPermission": "ALLOWED", "epub": {"isAvailable": false}, "pdf": {"isAvailable": false}, "webReaderLink": "http://play.google.com/books/reader?id=YjCeAAAACAAJ&hl=&source=gbs_api", "accessViewStatus": "NONE", "quoteSharingAllowed": false}}, {"kind": "books#volume", "id": "diDqvgEACAAJ", "etag": "qgMQ/mUGUaM", "selfLink": "https://www.googleapis.com/books/v1/volumes/diDqvgEACAAJ", "volumeInfo": {"title": "Batman: Year One (DC Black Label Edition)", "authors": ["FRANK. MILLER"], "publishedDate": "2019-06-11", "description": "He will become the greatest crimefighter the world has ever known. A Dark Alley. A faceless man with a gun. A child's life shattered forever. You know why Bruce Wayne becomes Batman, but do you know how? Frank Miller and David Mazzucchelli produced this groundbreaking reinterpretation of the origin of Batman--who he is, and how he came to be. Sometimes careless and naive, this Dark Knight was far from the flawless vigilante he is known as today. In his first year on the job, Batman feels his way around a Gotham City far darker than the one he left. His solemn vow to extinguish the town's criminal element is only half the battle; along with Lieutenant James Gordon, the Dark Knight must also fight a police force more corrupt than the scum in the streets. DC Black Label, a new publishing imprint from DC Entertainment, gives premier talent the opportunity to expand upon the canon of DC's iconic Super Hero comic book characters with unique, standalone stories that are outside of the current DC Universe continuity.Featuring an all-star lineup of creative teams that will craft their own personal definitive DC stories in the tradition of compelling literary works like Batman: The Killing Joke, All-Star Superman and Kingdom Come. Collects Batman #404-407", "industryIdentifiers": [{"type": "ISBN_10", "identifier": "1401291228"}, {"type": "ISBN_13", "identifier": "9781401291228"}], "readingModes": {"text": false, "image": false}, "pageCount": 0, "printType": "BOOK", "maturityRating": "NOT_MATURE", "allowAnonLogging": false, "contentVersion": "preview-1.0.0", "panelizationSummary": {"containsEpubBubbles": false, "containsImageBubbles": false}, "imageLinks": {"smallThumbnail": "http://books.google.com/books/content?id=diDqvgEACAAJ&printsec=frontcover&img=1&zoom=5&source=gbs_api", "thumbnail": "http://books.google.com/books/content?id=diDqvgEACAAJ&printsec=frontcover&img=1&zoom=1&source=gbs_api"}, "language": "en", "previewLink": "http://books.google.co.in/books?id=diDqvgEACAAJ&dq=dc+comics&hl=&cd=47&source=gbs_api", "infoLink": "http://books.google.co.in/books?id=diDqvgEACAAJ&dq=dc+comics&hl=&source=gbs_api", "canonicalVolumeLink": "https://books.google.com/books/about/Batman_Year_One_DC_Black_Label_Edition.html?hl=&id=diDqvgEACAAJ"}, "saleInfo": {"country": "IN", "saleability": "NOT_FOR_SALE", "isEbook": false}, "accessInfo": {"country": "IN", "viewability": "NO_PAGES", "embeddable": false, "publicDomain": false, "textToSpeechPermission": "ALLOWED", "epub": {"isAvailable": false}, "pdf": {"isAvailable": false}, "webReaderLink": "http://play.google.com/books/reader?id=diDqvgEACAAJ&hl=&source=gbs_api", "accessViewStatus": "NONE", "quoteSharingAllowed": false}, "searchInfo": {"textSnippet": "A child&#39;s life shattered forever. You know why Bruce Wayne becomes Batman, but do you know how? Frank Miller and David Mazzucchelli produced this groundbreaking reinterpretation of the origin of Batman--who he is, and how he came to be."}}, {"kind": "books#volume", "id": "imCzDwAAQBAJ", "etag": "Y5uBekiN2fQ", "selfLink": "https://www.googleapis.com/books/v1/volumes/imCzDwAAQBAJ", "volumeInfo": {"title": "Heroes in Crisis", "authors": ["Tom King"], "publisher": "DC Comics", "publishedDate": "2019-10-01", "description": "There\u2019s a new kind of crisis threatening the heroes of the DC Universe, ripped from real-world headlines by CIA operative turned comics writer Tom King: How does a superhero handle PTSD? Welcome to Sanctuary, an ultra-secret hospital for superheroes who\u2019ve been traumatized by crime-fighting and cosmic combat. But something goes inexplicably wrong when many patients wind up dead, with two well-known operators as the prime suspects: Harley Quinn and Booster Gold! It\u2019s up to the DC Trinity of Superman, Wonder Woman and Batman to investigate-but can they get the job done in the face of overwhelming opposition? This collected edition features the entire nine-issue miniseries!", "industryIdentifiers": [{"type": "ISBN_13", "identifier": "9781779503725"}, {"type": "ISBN_10", "identifier": "1779503725"}], "readingModes": {"text": true, "image": true}, "pageCount": 244, "printType": "BOOK", "categories": ["Comics & Graphic Novels"], "maturityRating": "NOT_MATURE", "allowAnonLogging": true, "contentVersion": "1.3.1.0.preview.3", "panelizationSummary": {"containsEpubBubbles": true, "containsImageBubbles": true, "epubBubbleVersion": "9dc707606ab30d3c_A", "imageBubbleVersion": "9dc707606ab30d3c_A"}, "imageLinks": {"smallThumbnail": "http://books.google.com/books/content?id=imCzDwAAQBAJ&printsec=frontcover&img=1&zoom=5&edge=curl&source=gbs_api", "thumbnail": "http://books.google.com/books/content?id=imCzDwAAQBAJ&printsec=frontcover&img=1&zoom=1&edge=curl&source=gbs_api"}, "language": "en", "previewLink": "http://books.google.co.in/books?id=imCzDwAAQBAJ&printsec=frontcover&dq=dc+comics&hl=&cd=48&source=gbs_api", "infoLink": "https://play.google.com/store/books/details?id=imCzDwAAQBAJ&source=gbs_api", "canonicalVolumeLink": "https://play.google.com/store/books/details?id=imCzDwAAQBAJ"}, "saleInfo": {"country": "IN", "saleability": "FOR_SALE", "isEbook": true, "listPrice": {"amount": 1453.46, "currencyCode": "INR"}, "retailPrice": {"amount": 726.73, "currencyCode": "INR"}, "buyLink": "https://play.google.com/store/books/details?id=imCzDwAAQBAJ&rdid=book-imCzDwAAQBAJ&rdot=1&source=gbs_api", "offers": [{"finskyOfferType": 1, "listPrice": {"amountInMicros": 1453460000, "currencyCode": "INR"}, "retailPrice": {"amountI